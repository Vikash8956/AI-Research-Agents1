PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/researchai

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=your_app_password

# IBM watsonx.ai
IBM_WATSONX_API_KEY=your_ibm_api_key
IBM_WATSONX_URL=https://us-south.ml.cloud.ibm.com
IBM_WATSONX_PROJECT_ID=your_project_id
IBM_GRANITE_MODEL_ID=ibm/granite-13b-instruct-v2

# IBM Cloud Object Storage
IBM_COS_API_KEY=your_cos_api_key
IBM_COS_INSTANCE_ID=your_instance_id
IBM_COS_ENDPOINT=https://s3.us-south.cloud-object-storage.appdomain.cloud
IBM_COS_BUCKET=researchai-bucket

# ChromaDB
CHROMA_URL=http://localhost:8000

# Frontend URL (CORS)
CLIENT_URL=http://localhost:3000
